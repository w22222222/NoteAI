<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootFrame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/rootContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_main"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/controlBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_edit_back_button"
                android:gravity="center"
                android:includeFontPadding="false"
                android:padding="0dp"
                android:text="@string/back_icon"
                android:textColor="@color/text_link"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/topBarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/titleEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edit_title"
            android:hint="@string/note_title_hint"
            android:inputType="textCapSentences"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/aiPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_ai_panel"
            android:elevation="1dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/aiPanelBadge"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_ai_badge"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="AI"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/aiPanelTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/aiPanelStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/aiPanelClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_ai_icon_button"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="@color/text_secondary"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/aiPanelContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:maxLines="10"
                android:scrollbars="vertical"
                android:textColor="@color/text_normal"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/aiSkeletonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:id="@+id/aiSkeletonRow1"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:background="@drawable/bg_ai_skeleton_row" />

                <View
                    android:id="@+id/aiSkeletonRow2"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_ai_skeleton_row" />

                <View
                    android:id="@+id/aiSkeletonRow3"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_ai_skeleton_row" />

                <View
                    android:id="@+id/aiSkeletonRow4"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_ai_skeleton_row" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/aiPolishActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btnAiUndo"
                    style="@style/AiSecondaryButtonStyle"
                    android:text="回退" />

                <TextView
                    android:id="@+id/btnAiRegenerate"
                    style="@style/AiSecondaryButtonStyle"
                    android:text="重新生成" />

                <TextView
                    android:id="@+id/btnAiConfirm"
                    style="@style/AiPrimaryButtonStyle"
                    android:text="确定" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/btnCategory"
                style="@style/EditActionButtonStyle"
                android:text="@string/category" />

            <TextView
                android:id="@+id/btnTag"
                style="@style/EditActionButtonStyle"
                android:text="@string/tag" />

            <TextView
                android:id="@+id/btnImage"
                style="@style/EditActionButtonStyle"
                android:text="@string/insert_image" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/modeToggleBtn"
                style="@style/EditActionButtonStyle"
                android:text="@string/preview" />

            <TextView
                android:id="@+id/btnSave"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_edit_save_button"
                android:gravity="center"
                android:text="@string/save_icon"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/topDivider"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#E5E7EB" />

        <FrameLayout
            android:id="@+id/mainArea"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/bg_main"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <ScrollView
                android:id="@+id/editScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_editor_card"
                android:fillViewport="true">

                <com.noteai.noteai.widget.RichTextEditor
                    android:id="@+id/contentEdit"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="@string/note_content_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:lineSpacingExtra="2dp"
                    android:lineSpacingMultiplier="1.15"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="16dp"
                    android:scrollbars="vertical"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="16sp" />
            </ScrollView>

            <com.noteai.noteai.widget.MarkdownRenderView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>

        <View
            android:id="@+id/bottomDivider"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#E5E7EB" />

        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/wordCountView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#999999"
            android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/aiSideActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <com.noteai.noteai.widget.AiActionButton
            android:id="@+id/btnAiSummaryAction"
            style="@style/AiActionButtonStyle"
            android:text="总结" />

        <com.noteai.noteai.widget.AiActionButton
            android:id="@+id/btnAiPolishAction"
            style="@style/AiActionButtonStyle"
            android:layout_marginTop="8dp"
            android:text="润色" />
    </LinearLayout>
</FrameLayout>
