<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/advancedSearchPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/advancedSearchHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/advancedSearchTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/advanced_search_title"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClearAdvancedSearch"
            style="@style/FilterButtonStyle"
            android:layout_marginEnd="0dp"
            android:enabled="false"
            android:text="@string/clear_filters"
            android:visibility="invisible" />

    </LinearLayout>

    <TextView
        android:id="@+id/searchScopeLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/search_scope"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/searchScopeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTitleOnlySearch"
            style="@style/FilterButtonStyle"
            android:text="@string/search_title_only" />

        <TextView
            android:id="@+id/btnFullTextSearch"
            style="@style/FilterButtonStyle"
            android:text="@string/search_full_text"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <TextView
        android:id="@+id/categoryFilterLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/category"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:id="@+id/categoryFilterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/categoryFilterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnAllCategories"
                style="@style/FilterButtonStyle"
                android:text="@string/all_categories" />

        </LinearLayout>

    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/tagSelectorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="top"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tagSelectorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:text="@string/tags_label"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tagSelectionDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="40dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/noSelectedTagsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="24dp"
                android:text="@string/not_available"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

            <HorizontalScrollView
                android:id="@+id/selectedTagsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/selectedTagsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
